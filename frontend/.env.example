# Copia este archivo como `.env` para desarrollo local (opcional).
# En producción, define VITE_WS_URL en el panel de Vercel.

# URL del endpoint WebSocket del backend.
# Local:      ws://localhost:8000/ws
# Producción: wss://TU-APP.onrender.com/ws   (¡wss, no ws, en HTTPS!)
VITE_WS_URL=ws://localhost:8000/ws

# ID del video de YouTube para la música de fondo (opcional).
# Es la parte después de "v=" en la URL del video:
#   https://www.youtube.com/watch?v=ESTE_ID
# Si se deja vacío, no hay música de fondo (los efectos siguen funcionando).
VITE_YOUTUBE_MUSIC_ID=
